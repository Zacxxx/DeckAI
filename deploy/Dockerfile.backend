FROM node:20-alpine
# Install Chromium and dependencies for headless browser validation
RUN apk add --no-cache \
    chromium \
    nss \
    freetype \
    harfbuzz \
    ca-certificates \
    ttf-freefont

WORKDIR /app
COPY backend/package*.json ./
RUN npm install

COPY backend/ .
RUN npx prisma generate

EXPOSE 8080
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser

CMD ["npm", "start"]
